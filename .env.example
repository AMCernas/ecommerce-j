# =============================================================================
# Stripe Payment Configuration
# =============================================================================

# Stripe Secret API Key (sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Signing Secret (whsec_...) - Get this from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Publishable Key (pk_test_... for test mode, pk_live_... for production)
# This is for frontend use with Stripe Elements
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Company Information for SPEI Transfers
# =============================================================================

# Legal company name for SPEI beneficiary field
COMPANY_NAME=ECOMMERCE JARDINERIA SA DE CV

# Company CLABE for receiving SPEI transfers (18-digit bank account reference)
COMPANY_CLABE=646180111812345678

# =============================================================================
# Payment Configuration (Optional)
# =============================================================================

# Hours until OXXO voucher expires (default: 72 hours / 3 days)
OXXO_VOUCHER_EXPIRY_HOURS=72

# Hours until SPEI transfer expires (default: 72 hours / 3 days)
SPEI_EXPIRY_HOURS=72

# Maximum age in seconds for webhook timestamp (default: 300 seconds / 5 minutes)
# This prevents replay attacks
WEBHOOK_TIMESTAMP_TOLERANCE=300

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable all payment endpoints (default: true in production)
PAYMENTS_ENABLED=true

# Individual payment method toggles (default: true)
ALLOW_CARD_PAYMENTS=true
ALLOW_OXXO_PAYMENTS=true
ALLOW_SPEI_PAYMENTS=true

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins for CORS (comma-separated list)
# Include your frontend domain(s)
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# =============================================================================
# Database Configuration
# =============================================================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecomerce_jardineria

# =============================================================================
# Email Configuration (Resend)
# =============================================================================

# Resend API Key - Get from https://resend.com/api-keys
# For development: Use test mode (free tier)
# For production: Use production key with verified domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default sender email address
# Development: Use onboarding@resend.dev (test mode)
# Production: Use your verified domain (e.g., orders@jardinverde.com)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Default sender name
RESEND_FROM_NAME=Jardín Verde
